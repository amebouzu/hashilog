# ========= 必須 =========
# Supabase の Project URL と公開鍵
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# サーバー側専用 (絶対公開しない)
# アカウント削除や Stripe Webhook の処理で必要
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# サイト URL (本番ドメイン or http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========= 任意 =========

# Cloudflare Web Analytics (Cookie 不要のアクセス解析)
# 設定すると Cloudflare のビーコンが自動で読み込まれる
NEXT_PUBLIC_CLOUDFLARE_BEACON_TOKEN=

# Google AdSense
# パブリッシャー ID (例: ca-pub-1234567890123456)。設定すると <head> に
# AdSense の async script が読み込まれ、<AdSenseSlot> コンポーネントが有効化される。
NEXT_PUBLIC_ADSENSE_CLIENT=

# Resend (お問い合わせフォーム通知メールに使用)
# API キーは Resend ダッシュボード → API Keys から発行する re_xxx の文字列。
# 設定がない場合、お問い合わせは DB に保存されるがメール通知は飛ばない。
RESEND_API_KEY=
# 通知先 (運営宛のメールアドレス)。未設定なら hashilog2024@gmail.com にフォールバック。
CONTACT_NOTIFY_TO=hashilog2024@gmail.com
# 送信元 (Resend で Verified 済みドメインの差出人)。形式は "表示名 <noreply@hashilog.jp>"
CONTACT_FROM=走ログ <noreply@hashilog.jp>

# Stripe (有料プラン billing_enabled で使用)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Sentry (エラートラッキング)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
